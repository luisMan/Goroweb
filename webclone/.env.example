# Browser-safe storefront settings
VITE_MERCADO_PAGO_PREFERENCE_ENDPOINT=/api/mercado-pago/preferences

# Local development proxy target for the checkout server
MERCADO_PAGO_SERVER_URL=http://localhost:8787

# Server-side Mercado Pago settings
# Keep these values out of client-side code.
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_SERVER_PORT=8787
MERCADO_PAGO_FRONTEND_ORIGIN=http://localhost:5173
MERCADO_PAGO_API_BASE_URL=https://api.mercadopago.com
MERCADO_PAGO_NOTIFICATION_URL=
MERCADO_PAGO_STATEMENT_DESCRIPTOR=BirdFuel
MERCADO_PAGO_SUCCESS_URL=
MERCADO_PAGO_FAILURE_URL=
MERCADO_PAGO_PENDING_URL=
